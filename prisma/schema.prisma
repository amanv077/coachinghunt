generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COACHING
  STUDENT
}

enum CoachingMode {
  OFFLINE
  ONLINE
  HYBRID
}

enum VerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum CourseType {
  COURSE
  BATCH
}

enum DeliveryMode {
  OFFLINE
  ONLINE
  HYBRID
}

enum DemoSlotStatus {
  OPEN
  FULL
  CANCELLED
  COMPLETED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OfferStatus {
  ACTIVE
  EXPIRED
  DRAFT
}

enum DemoRequestStatus {
  PENDING
  APPROVED
  RESCHEDULED
  DECLINED
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  ENROLLED
  DROPPED
}

enum QAStatus {
  PENDING
  ANSWERED
  HIDDEN
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

enum PostType {
  BLOG
  SUCCESS_STORY
}

enum ContentReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum FeaturedRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReferralStatus {
  PENDING
  COMPLETED
}

model User {
  id                    String           @id @default(cuid())
  name                  String
  email                 String           @unique
  passwordHash          String
  phone                 String?
  role                  UserRole
  isActive              Boolean          @default(true)
  emailVerifiedAt       DateTime?
  passwordResetToken    String?
  passwordResetExpires  DateTime?
  emailVerificationToken    String?
  emailVerificationExpires  DateTime?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  studentProfile  StudentProfile?
  coachingProfile CoachingProfile?
  auditLogs       AuditLog[]
  coachingQuestions CoachingQA[]   @relation("AskedByUser")
  blogReactions   BlogReaction[]
  blogComments    BlogComment[]
  contentReports  ContentReport[]
}

model StudentProfile {
  id                String    @id @default(cuid())
  userId            String    @unique
  city              String?
  classLevel        String?
  targetExams       String[]
  schoolName        String?
  preferredSubjects String[]
  referralCode      String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings          Booking[]
  reviews           Review[]
  demoRequests      DemoRequest[]
  savedCoachings    SavedCoaching[]
  referralsMade     Referral[] @relation("Referrer")
  referralsReceived Referral[] @relation("Referred")
}

model CoachingProfile {
  id                 String             @id @default(cuid())
  userId             String             @unique
  name               String
  slug               String             @unique
  tagline            String?
  description        String?
  foundedYear        Int?
  phone              String?
  alternatePhone     String?
  email              String?
  website            String?
  mode               CoachingMode         @default(OFFLINE)
  category           String?
  targetExams        String[]
  subjects           String[]
  facilities         String[]
  logoUrl            String?
  coverImageUrl      String?
  galleryImages      String[]
  city               String?
  locality           String?
  addressLine1       String?
  addressLine2       String?
  pincode            String?
  latitude           Float?
  longitude          Float?
  videoUrl           String?
  facultyProfiles    Json?
  achievementsText   String?
  avgResponseHours   Float?
  isFeatured         Boolean            @default(false)
  featuredUntil      DateTime?
  isPremium          Boolean            @default(false)
  verificationStatus VerificationStatus @default(PENDING)
  listingStatus      ListingStatus      @default(DRAFT)
  avgRating          Float              @default(0)
  reviewCount        Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  branches           CoachingBranch[]
  courses            Course[]
  demoSlots          DemoSlot[]
  bookings           Booking[]
  reviews            Review[]
  offers             Offer[]
  demoRequests       DemoRequest[]
  savedBy            SavedCoaching[]
  qaItems            CoachingQA[]
  profileViews       ProfileView[]
  feeRecords         PlatformFeeRecord[]
  featuredRequests   FeaturedRequest[]
  contentReports     ContentReport[]

  @@index([city])
  @@index([locality])
  @@index([isFeatured])
}

model CoachingBranch {
  id         String          @id @default(cuid())
  coachingId String
  branchName String
  city       String?
  locality   String?
  address    String?
  phone      String?
  isPrimary  Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  coaching   CoachingProfile @relation(fields: [coachingId], references: [id], onDelete: Cascade)
  courses    Course[]
  demoSlots  DemoSlot[]
}

model Course {
  id              String          @id @default(cuid())
  coachingId      String
  branchId        String?
  title           String
  slug            String          @unique
  description     String?
  courseType      CourseType      @default(BATCH)
  targetExams     String[]
  classLevel      String?
  subjectStream   String?
  facultySummary  String?
  language        String?
  batchSize       Int?
  deliveryMode    DeliveryMode    @default(OFFLINE)
  fees            Float?
  discountedFees  Float?
  durationText    String?
  startDate       DateTime?
  endDate         DateTime?
  scheduleSummary String?
  status          ListingStatus   @default(DRAFT)
  isFeatured      Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  coaching        CoachingProfile @relation(fields: [coachingId], references: [id], onDelete: Cascade)
  branch          CoachingBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  demoSlots       DemoSlot[]
  bookings        Booking[]
  reviews         Review[]
  demoRequests    DemoRequest[]

  @@index([coachingId])
}

model DemoSlot {
  id              String          @id @default(cuid())
  courseId        String
  coachingId      String
  branchId        String?
  topic           String
  teacherName     String
  teacherProfile  String?
  demoDate        DateTime
  startTime       String
  endTime         String
  durationMinutes Int
  capacity        Int
  bookedCount     Int             @default(0)
  venueName       String?
  venueAddress    String?
  instructions    String?
  joiningLink     String?
  status          DemoSlotStatus  @default(OPEN)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  course          Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  coaching        CoachingProfile @relation(fields: [coachingId], references: [id], onDelete: Cascade)
  branch          CoachingBranch? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  bookings        Booking[]
  demoRequests    DemoRequest[]

  @@index([courseId])
  @@index([demoDate])
  @@index([coachingId])
}

model Booking {
  id                 String          @id @default(cuid())
  studentId          String
  demoSlotId         String
  courseId           String
  coachingId         String
  bookingCode        String          @unique
  status             BookingStatus   @default(CONFIRMED)
  leadStatus         LeadStatus      @default(NEW)
  emailStatus        EmailStatus     @default(PENDING)
  reminderSent       Boolean         @default(false)
  reviewInviteSentAt DateTime?
  notes              String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  student            StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  demoSlot           DemoSlot        @relation(fields: [demoSlotId], references: [id], onDelete: Cascade)
  course             Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  coaching           CoachingProfile @relation(fields: [coachingId], references: [id], onDelete: Cascade)
  feeRecords         PlatformFeeRecord[]
  reviews            Review[]

  @@unique([studentId, demoSlotId])
  @@index([studentId])
  @@index([coachingId])
}

model Review {
  id         String          @id @default(cuid())
  studentId  String
  coachingId String
  courseId   String?
  bookingId  String?
  rating     Int
  title      String?
  comment    String?
  status     ReviewStatus    @default(PENDING)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  student    StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  coaching   CoachingProfile @relation(fields: [coachingId], references: [id], onDelete: Cascade)
  course     Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  booking    Booking?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  contentReports ContentReport[]

  @@unique([studentId, coachingId])
  @@index([coachingId])
  @@index([status])
}

model Offer {
  id          String          @id @default(cuid())
  coachingId  String
  title       String
  description String?
  promoCode   String?
  validFrom   DateTime
  validTill   DateTime
  status      OfferStatus     @default(ACTIVE)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  coaching    CoachingProfile @relation(fields: [coachingId], references: [id], onDelete: Cascade)

  @@index([coachingId])
  @@index([status])
}

model DemoRequest {
  id              String            @id @default(cuid())
  studentId       String
  coachingId      String
  courseId        String?
  preferredDate   DateTime?
  preferredTime   String?
  message         String?
  status          DemoRequestStatus @default(PENDING)
  leadStatus      LeadStatus        @default(NEW)
  coachingNotes   String?
  isPaidLead      Boolean           @default(false)
  responseNote    String?
  proposedDate    DateTime?
  proposedTime    String?
  resultingSlotId String?           @unique
  rescheduleOf    String?
  slaReminderSent Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  student         StudentProfile    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  coaching        CoachingProfile   @relation(fields: [coachingId], references: [id], onDelete: Cascade)
  course          Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  resultingSlot   DemoSlot?         @relation(fields: [resultingSlotId], references: [id], onDelete: SetNull)
  feeRecords      PlatformFeeRecord[]

  @@index([studentId])
  @@index([coachingId])
  @@index([status])
  @@index([leadStatus])
}

model SavedCoaching {
  id         String          @id @default(cuid())
  studentId  String
  coachingId String
  createdAt  DateTime        @default(now())
  student    StudentProfile  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  coaching   CoachingProfile @relation(fields: [coachingId], references: [id], onDelete: Cascade)

  @@unique([studentId, coachingId])
  @@index([studentId])
}

model CoachingQA {
  id            String          @id @default(cuid())
  coachingId    String
  askedByUserId String?
  question      String
  answer        String?
  status        QAStatus        @default(PENDING)
  isPublic      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  answeredAt    DateTime?
  coaching      CoachingProfile @relation(fields: [coachingId], references: [id], onDelete: Cascade)
  askedBy       User?           @relation("AskedByUser", fields: [askedByUserId], references: [id], onDelete: SetNull)
  contentReports ContentReport[]

  @@index([coachingId])
  @@index([status])
}

model ProfileView {
  id         String          @id @default(cuid())
  coachingId String
  date       DateTime
  viewCount  Int             @default(1)
  coaching   CoachingProfile @relation(fields: [coachingId], references: [id], onDelete: Cascade)

  @@unique([coachingId, date])
  @@index([coachingId])
  @@index([date])
}

model BlogPost {
  id            String     @id @default(cuid())
  title         String
  slug          String     @unique
  excerpt       String?
  content       String
  coverImageUrl String?
  tags          String[]
  postType      PostType   @default(BLOG)
  status        BlogStatus @default(DRAFT)
  publishedAt   DateTime?
  authorName    String?
  views         Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  reactions     BlogReaction[]
  comments      BlogComment[]

  @@index([status])
  @@index([postType])
}

model BlogReaction {
  id         String   @id @default(cuid())
  blogPostId String
  userId     String?
  ipAddress  String
  type       String   // "LIKE" or "DISLIKE"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, ipAddress, userId])
  @@index([blogPostId])
  @@index([userId])
}

model BlogComment {
  id         String   @id @default(cuid())
  blogPostId String
  userId     String
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([blogPostId])
  @@index([userId])
}

model PlatformFeeRecord {
  id             String          @id @default(cuid())
  coachingId     String
  demoRequestId  String?
  bookingId      String?
  enrolledByName String?
  amount         Float           @default(0)
  status         String          @default("PENDING")
  createdAt      DateTime        @default(now())
  coaching       CoachingProfile @relation(fields: [coachingId], references: [id], onDelete: Cascade)
  demoRequest    DemoRequest?    @relation(fields: [demoRequestId], references: [id], onDelete: SetNull)
  booking        Booking?        @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([coachingId])
  @@index([status])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  actorRole   UserRole
  action      String
  entityType  String
  entityId    String
  metaJson    Json?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model BlogQuery {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  blogSlug  String
  blogTitle String
  status    String   @default("PENDING") // PENDING, CONTACTED, FAKE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model ContentReport {
  id             String              @id @default(cuid())
  reporterUserId String
  coachingId     String?
  reviewId       String?
  qaId           String?
  reason         String
  status         ContentReportStatus @default(PENDING)
  adminNote      String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  reporter       User                @relation(fields: [reporterUserId], references: [id], onDelete: Cascade)
  coaching       CoachingProfile?    @relation(fields: [coachingId], references: [id], onDelete: SetNull)
  review         Review?             @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  qa             CoachingQA?         @relation(fields: [qaId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([coachingId])
}

model FeaturedRequest {
  id          String                @id @default(cuid())
  coachingId  String
  status      FeaturedRequestStatus @default(PENDING)
  note        String?
  adminNote   String?
  requestedAt DateTime              @default(now())
  reviewedAt  DateTime?
  coaching    CoachingProfile       @relation(fields: [coachingId], references: [id], onDelete: Cascade)

  @@index([coachingId])
  @@index([status])
}

model Referral {
  id             String         @id @default(cuid())
  referrerId     String
  referredUserId String?
  referralCode   String
  status         ReferralStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  referrer       StudentProfile @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred       StudentProfile? @relation("Referred", fields: [referredUserId], references: [id], onDelete: SetNull)

  @@index([referrerId])
  @@index([referralCode])
}
